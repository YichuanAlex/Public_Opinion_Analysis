!nd_prv_wlteh_webp_3""},{""image_scene"":""WB_DFT"",""url"":""http://sns-webpic-qc.xhscdn.com/202606220904/0b43b42f925da5d0c40f050713b1bd22/1040g008321lia12in40g5nkl6bvg8lgpevct1do!nd_dft_wlteh_webp_3""}],""url_pre"":""http://sns-webpic-qc.xhscdn.com/202606220904/00c336f49637f6ea300adce384402b60/1040g008321lia12in40g5nkl6bvg8lgpevct1do!nd_prv_wlteh_webp_3"",""url_default"":""http://sns-webpic-qc.xhscdn.com/202606220904/0b43b42f925da5d0c40f050713b1bd22/1040g008321lia12in40g5nkl6bvg8lgpevct1do!nd_dft_wlteh_webp_3"",""file_id"":"""",""height"":2338,""width"":1200,""url"":"""",""stream"":{}}],""at_user_list"":[],""time"":1782001331000,""last_update_time"":1782001331000,""ip_location"":""辽宁"",""share_info"":{""un_share"":false}}}],""current_time"":1782090290427}",,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,[],,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,15,综合,不限,一周内,不限,不限,https://www.xiaohongshu.com/search_result_ai?keyword=%E6%BB%B4%E6%BB%B4%E7%89%B9%E5%BF%AB&source=web_explore_feed&type=51,"综合,一周内",,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
滴滴特快,https://www.xiaohongshu.com/search_result_ai?keyword=%E6%BB%B4%E6%BB%B4%E7%89%B9%E5%BF%AB&source=web_explore_feed,49,https://www.xiaohongshu.com/search_result/6a34f433000000000803dc73?xsec_token=ABdaQY6AecABtGSye1LTp9ZSM3ZlT6kJPa3J4_WtuBqWU=&xsec_source=,6a34f433000000000803dc73,,滴滴顺风车千万不要选那个城际拼车！！！,"椒盐洋芋坨
1天前",,6a34f433000000000803dc73,note,6a34f433000000000803dc73,normal,滴滴顺风车千万不要选那个城际拼车！！！,"很久没有打顺风车，压根儿不知道这个城际拼车是什么，想着端午节多选一个打到车的概率高一些，就一起喊了。
	
抢单倒是快，默认跳转到了一个“玖玖专车”，第一个司机接单，我一看人家一直在往我的目的地方向走，还纳闷儿真的能在约定时间到达么，人家自己取消了。
第二次呼叫，还是玖玖专车接单，我看司机行程，一共要接4个人，我是第三个。平台显示15：20出行，到点我准备下楼了，刷新显示司机位置，结果离我30多公里，要70分钟才到。我取消订单，竟然要扣我15.19的费用？？？打他们客服专线，一直没人接，我就联系司机让他取消，他说一堆，讲现在不管我打什么车都要等这么久，我说你不用跟我讲这么多，你把我订单取消掉，好家伙人家急吼吼地说他取消不了，把电话挂了[微笑R]然后过了一两分钟？给我推送消息说司机取消订单了，不是取消不了吗[黑薯问号R]
	
我转头重新在滴滴上重新打了一个顺风车，准点上车，即使后面又去接了个人，我也在预计时间内到目的地了。[微笑R]
	
当年还能打上正儿八经的顺风车，现在实质上就是黑车平台，发布行程秒抢单，就算打独享，上车也会发现司机在不同平台用不同号接单，坐满一车人，根本不存在独享一说。打拼车也是，明明一车人，但是一样按没拼成算。
	
