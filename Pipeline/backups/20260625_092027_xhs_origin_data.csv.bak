ream"":{}},{""width"":1320,""url"":"""",""url_pre"":""http://sns-webpic-qc.xhscdn.com/202606171017/34b2f86d9ad413397572861b73f0b2f2/1040g008321gbs14t703g5n47alpk0vr2k2pj4jg!nd_prv_wlteh_webp_3"",""live_photo"":false,""height"":2868,""trace_id"":"""",""info_list"":[{""image_scene"":""WB_PRV"",""url"":""http://sns-webpic-qc.xhscdn.com/202606171017/34b2f86d9ad413397572861b73f0b2f2/1040g008321gbs14t703g5n47alpk0vr2k2pj4jg!nd_prv_wlteh_webp_3""},{""image_scene"":""WB_DFT"",""url"":""http://sns-webpic-qc.xhscdn.com/202606171017/dad85dabb433cfd90e086279296cfd47/1040g008321gbs14t703g5n47alpk0vr2k2pj4jg!nd_dft_wlteh_webp_3""}],""url_default"":""http://sns-webpic-qc.xhscdn.com/202606171017/dad85dabb433cfd90e086279296cfd47/1040g008321gbs14t703g5n47alpk0vr2k2pj4jg!nd_dft_wlteh_webp_3"",""stream"":{},""file_id"":""""}],""time"":1781652375000,""last_update_time"":1781652375000,""type"":""normal"",""title"":""避雷滴滴平台 太过分了！！！"",""desc"":""预约的顺风车 我选的独享 坐上车之后发现车上还有两人 其实这种情况已经比较普遍了 司机想多赚点钱我也没说啥了 但是走到一半司机告知我需要支付全部的高速费60元 我提出明明载了3位乘客为什么我要支付全部费用 我只能接受三人平摊 司机说让我找平台沟通 并给我看了他在同一个平台也就是滴滴 同时接的三单\n那我就很奇怪了 我选的是独享 为什么司机还能在这个平台上接其他乘客的单 后面仔细看发现订单备注上有司机会有亲友同行 才反应过来原来平台是打了这个信息差 让你以为其他乘客是司机的亲友实则不然 都是司机接的乘客\n立马和平台沟通 发现平台一直在推脱 全是官方话语也不解决问题 最后司机说如果我不支付全部高速费60元 他就停在服务区不走了 由于我要去赶飞机 还是支付给他60了\n请你们官方给我一个合理的答复！！！ @滴滴出行客服 @滴滴美好出发 @滴滴顺风车  #网约车[话题]# #顺风车[话题]# #消费者维护权益[话题]# #滴滴出行[话题]#"",""user"":{""xsec_token"":""ABdXLL320bdE3o-yYS_C40X3IfVhmYy63hTWRWUQnBlyU="",""user_id"":""5c8755730000000010007f62"",""nickname"":""Elara"",""avatar"":""https://sns-avatar-qc.xhscdn.com/avatar/1040g2jo31k4fvc9sia005n47alpk0vr2cf4mlc8""},""interact_info"":{""followed"":false,""relation"":""none"",""liked"":false,""liked_count"":""13"",""collected"":false,""collected_count"":""1"",""comment_count"":""5"",""share_count"":""2""}}}],""current_time"":1781662678216}",http://sns-video-v3.xhscdn.com/stream/1/10/19/01ea31db94343dd6010050039ed2c1ee54_19.mp4?sign=7ef4920c18ec4240219d8a99a2c48cf5&t=6a36a116,http://sns-bak-v1.xhscdn.com/stream/