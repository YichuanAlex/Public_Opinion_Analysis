v_wlteh_webp_3""},{""image_scene"":""WB_DFT"",""url"":""http://sns-webpic-qc.xhscdn.com/202606181336/23460744d5676e2821d61a9d7633ab64/1040g2sg321bc4iqm72jg4b4m4p1k6hl8mrih1k8!nd_dft_wlteh_webp_3""}],""live_photo"":false},{""url_default"":""http://sns-webpic-qc.xhscdn.com/202606181336/73b92dec7964de3cfee742e79ffb22f0/1040g2sg321bc4iqm72i04b4m4p1k6hl8u48at40!nd_dft_wlteh_webp_3"",""file_id"":"""",""width"":1080,""url"":"""",""trace_id"":"""",""live_photo"":false,""height"":2388,""info_list"":[{""url"":""http://sns-webpic-qc.xhscdn.com/202606181336/32c19b600dafbb50c682e6dced37ed2d/1040g2sg321bc4iqm72i04b4m4p1k6hl8u48at40!nd_prv_wlteh_webp_3"",""image_scene"":""WB_PRV""},{""image_scene"":""WB_DFT"",""url"":""http://sns-webpic-qc.xhscdn.com/202606181336/73b92dec7964de3cfee742e79ffb22f0/1040g2sg321bc4iqm72i04b4m4p1k6hl8u48at40!nd_dft_wlteh_webp_3""}],""url_pre"":""http://sns-webpic-qc.xhscdn.com/202606181336/32c19b600dafbb50c682e6dced37ed2d/1040g2sg321bc4iqm72i04b4m4p1k6hl8u48at40!nd_prv_wlteh_webp_3"",""stream"":{}}],""interact_info"":{""comment_count"":""52"",""share_count"":""3"",""followed"":false,""relation"":""none"",""liked"":false,""liked_count"":""9"",""collected"":false,""collected_count"":""1""},""last_update_time"":1781316811000,""share_info"":{""un_share"":false},""type"":""normal"",""title"":""滴滴师傅: 同行内卷？总归成就了平台。"",""desc"":""以前都吐槽，特惠谁接啊？（可，特惠当年还有1.5～1.7元/公里）\n上一年25年，随心接，还能自己选1.3～1.7元，接哪个价格段。\n——————\n**如今。。。。。2026年6月\n每逢周五六日，主推随心接\n过节/放假，加大力度主推。\n随心接免佣。不还是一口价？\n导航显示半小时送达，开始行程后跑了1个小时，懂的都懂。\n一口价:30分钟挣30元 Vs 60分钟挣30元的区别。需要跑至少27公里。。觉得不亏就行。能一样吗？？\n【但凡接特惠，堵车至少还能给你多跳几元钱。。一口价随心接堵完免佣，能多给的金额（免佣）平台早就掐着。掏不了任何好。\n再叠一下乘客的优惠券。哈哈哈哈。免佣多给师傅2.3元】\n\t\n平峰期，随心接1.1元/公里\n高峰期，（图1）才有1.2～1.4元/公里，免佣完能给1.5元/公里就不错了。\n然而。。。。\n花60分钟\n①跑27公里挣30元\n②跑4单特惠起步价，也是到手30\n我宁可选后者。哪怕没4单，就3单也不至于被一口价整得心烦。\n\t\n真的给我一种错觉:\n好多同行，还不知道乘客给的钱就这么多。平台就是按一口价计算给师傅的。就非得主动去接受一口价，还是越堵车越不跳表的随心接。\n反正，人教人教不会，平台潜规则就懂了就老实了。\n\t\n[doge][doge]\n继续帮平台内卷吧，\n特惠/快车降价，我作为师傅都还能无可奈何的理解。\n随心接都还能义无反顾的抢/接，平台真得感谢某些同行了。\n也让平台更有底气继续降价。\n[doge]别和我扯，不还是为了生活，混口饭吃。\n谁不用吃饭？谁不用养家似的。\n随心接从1.7元/公里，一路掉到1.1元/公里，或许年底还能降到0.8元/公里。\n[doge]不正是没底气，没骨气的同行内卷后导致的？？平台知道会有师傅忍不住接，那就更有底气继续降价拿捏🤏🏻，不是吗？？\n[大笑R][大笑R]*希望这些同行，充电不用钱，车子不用保养，不用吃喝拉撒。纯铁打的。。\n\t\n（图3）城际拼车，\n30.4公里，一口价31。\n也很需要随心接同行们的出手和努力呢[微笑R]""}}],""current_time"":1781760989142}",,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,[],,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,5,综合,不限,一周内,不限,不限,https://www.xiaohongshu.com/search_result_ai?keyword=%E6%BB%B4%E6%BB%B4%E7%89%B9%E6%83%A0&source=web_explore_feed&type=51,"综合,一周内",,,,,,,,[],,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
