e"":""WB_DFT"",""url"":""http://sns-webpic-qc.xhscdn.com/202606171018/63c38719833d7c1392cfd6311ab4c6cc/notes_pre_post/1040g3k8321ffrd2g7e9g5o4plm8g8utsap285mg!nd_dft_wgth_webp_3""}],""url_pre"":""http://sns-webpic-qc.xhscdn.com/202606171018/a0cb5623d714da18e80f1a125060a188/notes_pre_post/1040g3k8321ffrd2g7e9g5o4plm8g8utsap285mg!nd_prv_wgth_webp_3"",""url_default"":""http://sns-webpic-qc.xhscdn.com/202606171018/63c38719833d7c1392cfd6311ab4c6cc/notes_pre_post/1040g3k8321ffrd2g7e9g5o4plm8g8utsap285mg!nd_dft_wgth_webp_3""}],""time"":1781594078000,""ip_location"":""天津"",""interact_info"":{""collected_count"":"""",""comment_count"":""2"",""share_count"":""1"",""followed"":false,""relation"":""none"",""liked"":false,""liked_count"":""4"",""collected"":false},""tag_list"":[{""id"":""5d8b032f000000000103bc0f"",""name"":""发票"",""type"":""topic""},{""id"":""5c0406f17c10ee00012f1d55"",""name"":""滴滴"",""type"":""topic""},{""id"":""5c98635a000000000d03fb1d"",""name"":""滴滴出行"",""type"":""topic""},{""name"":""消费者权益"",""type"":""topic"",""id"":""5c7cf36a000000000f00ac4a""},{""id"":""5c8b8afa000000000f006d3e"",""name"":""维护权益"",""type"":""topic""}],""illegal_info"":{""link"":""xhsdiscover://rn/kuri/noteStickers?background_transparent_v2=true&needNewRootNavigation=true&noteId=6a30f7de000000001603eda0"",""desc"":""可能含AI生成内容"",""left_icon"":""https://picasso-static.xiaohongshu.com/fe-platfrom/bc740cc162107169b504c4c1e5ee35f92eaa8456.png""},""note_id"":""6a30f7de000000001603eda0"",""type"":""normal"",""title"":""滴滴打车不给开发票冷处理"",""at_user_list"":[{""user_id"":""61b2e3b8000000001000b65a"",""nickname"":""滴滴出行客服"",""xsec_token"":""ABVvFcK_3c6uLbstEyZA3gSywA2dSbby_YhqkqRfaM3aw=""}],""last_update_time"":1781594079000,""share_info"":{""un_share"":false},""desc"":""6月5日晚上打的车，滴滴平台自动勾选了出租车这个选项，可能该软件是基于当时加完班时间比较晚，附近叫车难的情况。本人之前从未主动添加过出租车。\n好，此刻我还浑然不知一场闹剧的开始[汗颜R]。在等车时、上车落座后，不论是滴滴平台或是语音播报均未提醒消费者向司机询问纸质发票，并且出租车车上无打表器，问司机说是此单是特惠单发票要线上开。\n5号当晚订单结束付款后我在线上开发票，发现根本不让开票。联系客服，让填链接写问卷；召唤人工，依然打太极，说1-5个工作日会处理，还欺骗消费者后续会补发发票。我心存疑惑，想着第二天打个电话再问一下吧，这一问可好，人工电话客服小哥哥说滴滴这边全程负责去找出租车公司要纸质发票，并且平台会承担邮寄发票的运费——说得有鼻子有眼的，把人骗的团团转，我对滴滴的信任就这样喂了狗。\n我如实跟主管说了，主管先给垫付了，让我过两天来补发票。这一晃10天过去了，等不起了，我又再次找人工客服，说你们这处理超时了。这才“通知”我这票根本没法开，给出的处理方法就是补偿一张“仅限出租车使用”的20块的券。\n我这下彻底被激怒了，滴滴平台居然不开具在你平台上支付的账单发票？？？还踢皮球给出租车公司，这单派的就是一口价平台单，司机也说去线上下载发票，消费者在平台付了钱，两端互相推诿，没有一方给个痛快话。最可恨的是还欺骗消费者，把战线拖长冷处理，如果消费者忘了这茬，滴滴是不是就算拍屁股走人了？？给20块的出租车消费券，在这恶心谁呢？好比点外卖在你家吃出虫子你给一张仅限你家使用的5r代金券，吃相不要太难看吧！\n#发票[话题]# #滴滴[话题]# #滴滴出行[话题]# #消费者权益[话题]# #维护权益[话题]# @滴滴出行客服""}}],""current_time"":1781662693542}",,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,6,综合,不限,一天内,不限,不限,https://www.xiaohongshu.com/search_result_ai?keyword=%E6%BB%B4%E6%BB%B4%E6%89%93%E8%BD%A6&source=web_explore_feed&type=51,"综合,一天内",,,,,,,,,可能含AI生成内容,https://picasso-static.xiaohongshu.com/fe-platfrom/bc740cc162107169b504c4c1e5ee35f92eaa8456.png,xhsdiscover://rn/kuri/noteStickers?background_transparent_v2=true&needNewRootNavigation=true&noteId=6a30f7de000000001603eda0,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
