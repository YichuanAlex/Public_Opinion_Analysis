d1tr2f39hh8!nd_prv_wgth_webp_3"",""stream"":{},""live_photo"":false,""info_list"":[{""image_scene"":""WB_PRV"",""url"":""http://sns-webpic-qc.xhscdn.com/202606181315/e8b999b9e8da39783cb2f0301d18c56f/spectrum/1040g34o321hp529un2105oln0qkmd1tr2f39hh8!nd_prv_wgth_webp_3""},{""image_scene"":""WB_DFT"",""url"":""http://sns-webpic-qc.xhscdn.com/202606181315/8ff65a29252a6ec01bd5e7e5f3e3b785/spectrum/1040g34o321hp529un2105oln0qkmd1tr2f39hh8!nd_dft_wgth_webp_3""}]}],""tag_list"":[{""name"":""女司机"",""type"":""topic"",""id"":""5c170bd60000000003021b4b""},{""id"":""6710a63300000000030194b1"",""name"":""大学生实习"",""type"":""topic""},{""id"":""5e566c22000000000100b19e"",""name"":""互联网大厂实习"",""type"":""topic""},{""id"":""54afa5abb4c4d66d197c4855"",""name"":""女性"",""type"":""topic""},{""id"":""5c0b8d4c0990ae0001f65f53"",""name"":""开车"",""type"":""topic""},{""id"":""5ac48382e39faf22eaea9747"",""name"":""我的实习生活"",""type"":""topic""},{""id"":""621835f3000000000100898d"",""name"":""手握方向盘的安全感"",""type"":""topic""},{""id"":""5e665d700000000001000cbe"",""name"":""手握方向盘"",""type"":""topic""},{""id"":""610dbdae000000000101d978"",""name"":""开车要小心"",""type"":""topic""},{""id"":""5f476c8a000000000100781c"",""name"":""开车出去玩"",""type"":""topic""}],""time"":1781746541000,""last_update_time"":1781746542000,""type"":""normal"",""title"":""打一个月女司机的车有感"",""user"":{""user_id"":""62b706a900000000190287bb"",""nickname"":""半眠"",""avatar"":""https://sns-avatar-qc.xhscdn.com/avatar/1040g2jo31ncjqoo26m005oln0qkmd1trr25unj8"",""xsec_token"":""ABWPuxxwj-ktpoV02ID4tQB6asy4WN6-BHCBcJtwig5es=""},""share_info"":{""un_share"":false},""ip_location"":""浙江"",""note_id"":""6a334b6d0000000007026a43"",""desc"":""杭州进入梅雨季之后，这一个月经常打车，每次基本都会用滴滴优先匹配女司机。\n所以这一个月，遇到了很多很多女司机。\n比如某天的大暴雨让撑伞的我分外狼狈，司机阿姨会特意把车停到避雨的商铺旁边，让我慢慢过来不着急。\n比如几次下班碰上晚高峰，堵车严重路况很差，司机姐姐全程稳稳开车，过隧道的时候不急躁不超车，安安稳稳把我送到目的地（我是一个比较害怕长时间在隧道里的人）。\n再比如拍完毕业照回学校的时候，司机阿姨会恭喜我们毕业，并骄傲地说自己也有一个和我们一样大的女儿，今年也毕业了。\n再比如脚受伤的时候，司机阿姨会主动下车帮我放行李，停车的时候把我送到大门口，慢慢等我下车。\n\t\n印象最深的是一次雨后初晴，车窗搬开，司机阿姨放着轻柔的老歌。路过西湖时，我在熙熙攘攘的人群里，恰好看到了最美的晚霞。\n一个月，这座城市在雨季里的温柔，被这些开车的姐姐阿姨们，一程一程送到了我的面前。感谢女司机们的存在，让女孩们更安心。\n#女司机[话题]# #大学生实习[话题]# #互联网大厂实习[话题]# #女性[话题]# #开车[话题]# #我的实习生活[话题]# #手握方向盘的安全感[话题]# #手握方向盘[话题]# #开车要小心[话题]# #开车出去玩[话题]#"",""at_user_list"":[]},""id"":""6a334b6d0000000007026a43""}],""current_time"":1781759716598}",,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,[],,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,610dbdae000000000101d978,开车要小心,topic,5f476c8a000000000100781c,开车出去玩,topic,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,4,综合,不限,一周内,不限,不限,https://www.xiaohongshu.com/search_result_ai?keyword=%E6%BB%B4%E6%BB%B4%E5%A5%B3%E5%8F%B8%E6%9C%BA&source=web_explore_feed&type=51,"综合,一周内",,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
