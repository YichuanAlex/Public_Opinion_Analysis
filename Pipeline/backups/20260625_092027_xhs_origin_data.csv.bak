2d950,年轻人更爱喝了无糖茶,1718791909000,,https://sns-avatar-qc.xhscdn.com/avatar/1040g2jo31gcn9ple3u0049hiom8kjmh8erfe13o,ABJq3Oi8oBAuzbouWi_pAoVaM_IpMDdRcPHKn_4q5fyU0=,5929914950c4b412ff57da28,hi nana,64549a6800000000120347dc,果子熟了无糖茶,ABG6Xt2-coUiipT2IDACgH9BjK9E0gMt7dAWVlpqwKxIY=,1719820463000,False,1781607626961,"{""current_time"":1781607626961,""cursor_score"":"""",""items"":[{""id"":""6672a8b6000000001c037b3f"",""model_type"":""note"",""note_card"":{""type"":""normal"",""title"":""在北京！打到惊喜彩蛋车！被治愈了！"",""desc"":""谁懂啊\n打车打到了彩蛋车了！果子熟了无糖茶滴滴香香车！\n一整个车都是夏天的味道~\n车里香香的，是栀子花的香味🌸\n\t\n车座位还放了栀子花和栀栀乌龙无糖茶\n这该死的仪式感！太让人惊喜了😄\n\t\n后排还能看到紫妹的美照！\n这装饰和服务简直太棒啦！\n干净软糯的抱枕，而且连安全带都是栀子花🌸的图案，满满小细节\n还有车窗贴的文案：“花味弄一点，班味就淡一点”\n职场人表示真的被治愈了[飞吻R]@果子熟了无糖茶\n\t\n#好喝的茶饮料[话题]# #适合夏天的饮料[话题]# #果子熟了[话题]# #杨紫同款[话题]##果子熟了无糖茶代言人杨紫[话题]# #果子熟了无糖茶[话题]# #果子熟了[话题]##果子熟了送你夏日好栀味[话题]# #年轻人更爱喝了无糖茶[话题]#"",""user"":{""user_id"":""5929914950c4b412ff57da28"",""nickname"":""hi nana"",""avatar"":""https://sns-avatar-qc.xhscdn.com/avatar/1040g2jo31gcn9ple3u0049hiom8kjmh8erfe13o"",""xsec_token"":""ABJq3Oi8oBAuzbouWi_pAoVaM_IpMDdRcPHKn_4q5fyU0=""},""at_user_list"":[{""user_id"":""64549a6800000000120347dc"",""nickname"":""果子熟了无糖茶"",""xsec_token"":""ABG6Xt2-coUiipT2IDACgH9BjK9E0gMt7dAWVlpqwKxIY=""}],""time"":1718791909000,""share_info"":{""un_share"":false},""note_id"":""6672a8b6000000001c037b3f"",""interact_info"":{""share_count"":""39"",""followed"":false,""relation"":""none"",""liked"":false,""liked_count"":""153"",""collected"":false,""collected_count"":""23"",""comment_count"":""13""},""image_list"":[{""url_default"":""http://sns-webpic-qc.xhscdn.com/202606161900/df4240261c0982d267006e4f3d3fb452/1040g0083147lapkhka0049hiom8kjmh8aq4oaho!nd_dft_wlteh_webp_3"",""file_id"":"""",""height"":2560,""width"":1920,""trace_id"":"""",""url_pre"":""http://sns-webpic-qc.xhscdn.com/202606161900/4312f8f6791da1bd32cddfa847dd26f6/1040g0083147lapkhka0049hiom8kjmh8aq4oaho!nd_prv_wlteh_webp_3"",""url"":"""",""info_list"":[{""image_scene"":""WB_PRV"","